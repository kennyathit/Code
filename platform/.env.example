# ── Local (default): SQLite file, zero accounts ──────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Deploy (free): Supabase Postgres — paste the "Connection string" from
#    Supabase ▸ Project Settings ▸ Database, and change the provider in
#    prisma/schema.prisma from "sqlite" to "postgresql".
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── Optional: a single shared code the group types to get in (deploy only).
# GROUP_PASSWORD="changeme"
