# ── Local development (default): SQLite file, zero accounts ───────────────────
DATABASE_URL="file:./dev.db"

# ── Deploy (free): Supabase Postgres + Supabase Storage ───────────────────────
# Set these in Vercel ▸ Project ▸ Settings ▸ Environment Variables (and locally
# in a .env if you want to seed the cloud DB from your machine).
#
# 1) Database connection string — Supabase ▸ Project Settings ▸ Database ▸
#    "Connection string" (URI). Use the pooled (port 6543) string for the app.
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# 2) PDF storage — Supabase ▸ Project Settings ▸ API.
# SUPABASE_URL="https://[REF].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."   # keep secret, server only
# SUPABASE_BUCKET="materials"                          # the Storage bucket name
